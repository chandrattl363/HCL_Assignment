# ---------------------------------------------------------------------------
# LLM provider: Groq (free, generous tier; serves open-source models w/ tool-calling)
# ---------------------------------------------------------------------------
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Provider-qualified model spec. Default is groq:llama-3.3-70b-versatile.
# Other good tool-calling options: groq:llama-3.1-8b-instant, groq:openai/gpt-oss-20b
LLM_MODEL=groq:llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Open-source embedding model for FAISS policy retrieval (local, no API key)
# ---------------------------------------------------------------------------
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
